
Function RunPython(pyScript As String, action As String, wbPath As String) As Long
    Dim wsh As Object
    Dim cmd As String
    Dim exitCode As Long
    
    Set wsh = CreateObject("WScript.Shell")
    
    ' 횕챤챘챠횪첼 챗챤챙횪챠채횪 챰 챦책챨책채횪첨책챕 챦책챨책챙책챠챠청천 챤챗챨처챈책챠챔첼
cmd = "cmd /c py -3.11 """ & pyScript & """ " & action & " """ & wbPath & _
      """ >> """ & Left(wbPath, InStrRev(wbPath, "\")) & "breedingSync.log"" 2>&1"
    
    ' 횘챨책챵챔챕 챦횪챨횪챙책챵챨 = True -> 횈횆짢횘 챌횪창책챨첩책챠챔첼
    exitCode = wsh.Run(cmd, 0, True)
    
    RunPython = exitCode
End Function


