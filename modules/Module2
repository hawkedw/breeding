' Module2 — PythonRunner
Option Explicit

Private Declare PtrSafe Sub Sleep Lib "kernel32" (ByVal dwMilliseconds As LongPtr)

Private Const PY_EXE    As String = "C:\Python311\python.exe"
Private Const PY_SCRIPT As String = "breedingSync.py"


Function RunPython(action As String) As Long
    Dim script  As String
    Dim logFile As String
    Dim cmd     As String
    Dim wsh     As Object

    script  = ThisWorkbook.Path & "\" & PY_SCRIPT
    logFile = ThisWorkbook.Path & "\breedingSync.log"

    cmd = Chr(34) & PY_EXE & Chr(34) & " " & _
          Chr(34) & script & Chr(34) & " " & action & _
          " 1>>" & Chr(34) & logFile & Chr(34) & " 2>&1"

    LogVba "cmd = cmd.exe /c """ & cmd & """"

    Set wsh = CreateObject("WScript.Shell")
    RunPython = wsh.Run("cmd.exe /c """ & cmd & """", 0, True)
    Set wsh = Nothing
End Function


' RunPythonWithWb:
'   1. Запуск Python асинхронно (False) — Excel не блокируется
'   2. Ожидает флаг через Sleep+DoEvents (освобождает COM для Python)
Function RunPythonWithWb(action As String) As Long
    Dim script   As String
    Dim wbPath   As String
    Dim logFile  As String
    Dim pidFile  As String
    Dim cmd      As String
    Dim wsh      As Object
    Dim maxTicks As Long
    Dim tick     As Long

    script  = ThisWorkbook.Path & "\" & PY_SCRIPT
    wbPath  = ThisWorkbook.FullName
    logFile = ThisWorkbook.Path & "\breedingSync.log"
    pidFile = ThisWorkbook.Path & "\_done.flag"

    On Error Resume Next
    Kill pidFile
    On Error GoTo 0

    cmd = Chr(34) & PY_EXE & Chr(34) & " " & _
          Chr(34) & script & Chr(34) & " " & action & " " & _
          Chr(34) & wbPath & Chr(34) & _
          " 1>>" & Chr(34) & logFile & Chr(34) & " 2>&1" & _
          " && echo done>" & Chr(34) & pidFile & Chr(34)

    LogVba "cmd = cmd.exe /c """ & cmd & """"

    Set wsh = CreateObject("WScript.Shell")
    wsh.Run "cmd.exe /c """ & cmd & """", 0, False
    Set wsh = Nothing

    ' Поллинг 200 мс — максимальная задержка 200 мс после завершения Python
    maxTicks = 1500   ' 1500 x 200ms = 300 sec timeout
    tick = 0
    Do While tick < maxTicks
        Sleep 200
        DoEvents
        tick = tick + 1
        If tick Mod 5 = 0 Then
            Application.StatusBar = "Ожидание Python... " & (tick \ 5) & "s"
        End If
        If Dir(pidFile) <> "" Then
            On Error Resume Next
            Kill pidFile
            On Error GoTo 0
            Application.StatusBar = False
            RunPythonWithWb = 0
            Exit Function
        End If
    Loop

    Application.StatusBar = False
    LogVba "RunPythonWithWb TIMEOUT after 300s"
    RunPythonWithWb = 1
End Function


Sub LogVba(msg As String)
    Dim logFile As String
    Dim ts      As String
    Dim fNum    As Integer

    logFile = ThisWorkbook.Path & "\breedingSync.log"
    ts = Format(Now, "[YYYY-MM-DD HH:MM:SS]")

    On Error Resume Next
    fNum = FreeFile
    Open logFile For Append As #fNum
    Print #fNum, ts & " [VBA] " & msg
    Close #fNum
    On Error GoTo 0
End Sub
